---
import { withBase } from "../lib/paths";

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;

const links = [
  { href: withBase("/"), label: "Home" },
  { href: withBase("/blog/"), label: "Blog" },
  { href: withBase("/albums/"), label: "Albums" },
];
---

<header class="mb-12 sm:mb-16">
  <div class="rounded-[2rem] border border-black bg-black px-4 py-3 sm:rounded-full sm:px-2 sm:py-2" style="box-shadow: 10px 10px 0 #1a8a47;">
    <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between sm:gap-4">
      <a
        href={withBase("/")}
        class="rounded-full bg-accent px-3 py-1 text-xl font-medium tracking-tight whitespace-nowrap text-white hover:bg-white hover:text-black sm:px-4 sm:py-2 sm:text-sm"
      >
        Yang Kunyi
      </a>

      <nav class="grid grid-cols-3 gap-1 sm:flex sm:items-center">
        {
          links.map((link) => {
            const active =
              link.href === withBase("/")
                ? currentPath === withBase("/")
                : currentPath.startsWith(link.href);

            return (
              <a
                href={link.href}
                class:list={[
                  "rounded-full px-3 py-2.5 text-center font-mono text-[0.78rem] uppercase tracking-[0.18em] sm:px-4 sm:py-2 sm:text-[0.7rem]",
                  active
                    ? "bg-accent text-white"
                    : "text-white hover:bg-white hover:text-black",
                ]}
              >
                {link.label}
              </a>
            );
          })
        }
      </nav>
    </div>
  </div>
</header>
